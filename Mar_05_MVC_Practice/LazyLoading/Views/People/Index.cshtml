@model IEnumerable<LazyLoading.Models.Person>

@{
    ViewData["Title"] = "People";
}

<h1>People List (Lazy Loading Demo)</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>BusinessEntityId</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email Count (Lazy Loading)</th>
            <th>Phone Count (Lazy Loading)</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BusinessEntityId</td>

                <td>@item.FirstName</td>

                <td>@item.LastName</td>

                <!-- Lazy Loading happens here -->
                <td>@item.EmailAddresses.Count</td>

                <!-- Lazy Loading happens here -->
                <td>@item.PersonPhones.Count</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.BusinessEntityId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BusinessEntityId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BusinessEntityId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<div class="mt-3">

    @* @if (ViewBag.CurrentPage > 1)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">Previous</a>
    } *@

    <div style="margin-top:20px">

        @if (ViewBag.CurrentPage > 1)
        {
            <a asp-action="Index"
               asp-route-page="@(ViewBag.CurrentPage - 1)"
               class="btn btn-primary">
                Previous
            </a>%
        }

        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <a asp-action="Index"
               asp-route-page="@(ViewBag.CurrentPage + 1)"
               class="btn btn-primary">
                Next
            </a>
        }

    </div>

    @* @if (ViewBag.CurrentPage < ViewBag.TotalPages)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">Next</a>
    } *@

</div>