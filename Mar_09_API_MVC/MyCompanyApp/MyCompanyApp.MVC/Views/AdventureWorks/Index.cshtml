@model List<MyCompanyApp.MVC.Models.PersonViewModel>

<h2 class="mb-3">Adventure Works Employees</h2>

<table id="peopleTable" class="display">

    <thead>
        <tr>
            <th>ID</th>
            <th>Type</th>
            <th>First Name</th>
            <th>Middle Name</th>
            <th>Last Name</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.BusinessEntityId</td>
                <td>@item.PersonType</td>
                <td>@item.FirstName</td>
                <td>@item.MiddleName</td>
                <td>@item.LastName</td>
            </tr>
        }

    </tbody>

</table>


@section Scripts {

    <script>

        $(document).ready(function () {

            $('#peopleTable').DataTable({

                pageLength: 10,

                lengthMenu: [10, 25, 50, 100],

                ordering: true,

                searching: true

            });

        });

    </script>

}